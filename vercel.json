{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/", "destination": "/demo/index.html" }
  ],
  "functions": {
    "api/analyze.py": {
      "memory": 1024,
      "maxDuration": 30,
      "includeFiles": "{src/**,data/candidates/**}"
    }
  }
}